---
// Single EthicalAds text placement — privacy-respecting, dev-audience ads.
// Renders nothing until support.ethicalAdsPublisher is set in src/lib/site.mjs.
import { support } from '../lib/site.mjs';
const publisher = support.ethicalAdsPublisher;
---
{publisher && (
  <div style="margin: 14px 0 2px;">
    <div data-ea-publisher={publisher} data-ea-type="text"></div>
    <script async src="https://media.ethicalads.io/media/client/ethicalads.min.js"></script>
  </div>
)}
