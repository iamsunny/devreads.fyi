---
import { siteById, hueOf, tagCounts, MIN_TAG_COUNT, tagSlug } from '../lib/data.mjs';
const { post, showSource = true } = Astro.props;
const root = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const site = siteById.get(post.siteId);
const name = site?.name ?? post.siteId;
const dateStr = post.published
  ? new Date(post.published).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })
  : null;
---
<article
  class="row"
  data-id={post.id}
  data-url={post.url}
  data-published={post.published}
  data-title={post.title}
  data-source={name}
>
  <span class="avatar" style={`--h:${hueOf(post.siteId)}`} aria-hidden="true">{name[0].toUpperCase()}</span>
  <div class="row-main">
    <p class="meta">
      {showSource && <a class="src" href={`${root}source/${post.siteId}/`}>{name}</a>}
      {dateStr && <time data-rel datetime={post.published}>{dateStr}</time>}
      {post.readingMin && <span>{post.readingMin} min read</span>}
    </p>
    <h3 class="title"><a href={post.url} target="_blank" rel="noopener">{post.title}</a></h3>
    {post.summary && <p class="summary">{post.summary}</p>}
    {post.tags?.length > 0 && (
      <p class="tags">
        {post.tags.map((t) =>
          (tagCounts.get(t) ?? 0) >= MIN_TAG_COUNT
            ? <a class="chip" href={`${root}tag/${tagSlug(t)}/`}>{t}</a>
            : <span class="chip">{t}</span>
        )}
      </p>
    )}
  </div>
  <button class="save-btn" aria-label="Save post" title="Save for later">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path class="fill" d="M6 3h12v18l-6-4.5L6 21Z" stroke-linejoin="round"/></svg>
  </button>
</article>
