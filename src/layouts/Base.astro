---
import { posts } from '../lib/data.mjs';
const { title = 'Engineering reads', description = 'Engineering blogs, aggregated — with instant search' } = Astro.props;
const root = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const postCount = posts.length.toLocaleString('en-US');
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href={`data:image/svg+xml,${encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path fill="%23e05d38" d="M4 4a16 16 0 0 1 16 16h-3A13 13 0 0 0 4 7Zm0 7a9 9 0 0 1 9 9h-3a6 6 0 0 0-6-6Zm0 7a2 2 0 1 1 0 4 2 2 0 0 1 0-4Z"/></svg>').replaceAll('%2523', '%23')}`} />
  <link rel="alternate" type="application/rss+xml" title="Engineering reads" href={`${root}feed.xml`} />
  <style is:global>
    :root {
      --bg: #fdfdfc; --surface: #f4f3f0; --fg: #1b1b18; --muted: #6c6a64; --faint: #98968e;
      --border: #e4e2dc; --accent: #4456d0; --accent-bg: #e9ecfb; --danger: #b3362c; --ok: #2c7a4b;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #16161a; --surface: #1f1f24; --fg: #e8e6e1; --muted: #a3a19a; --faint: #76746e;
        --border: #2d2d33; --accent: #93a0f0; --accent-bg: #272c45; --danger: #e08379; --ok: #7bc99a;
      }
    }
    * { box-sizing: border-box; }
    body {
      margin: 0; background: var(--bg); color: var(--fg);
      font: 15px/1.55 system-ui, 'Segoe UI', Roboto, sans-serif;
    }
    a { color: inherit; text-decoration: none; }
    .wrap { max-width: 780px; margin: 0 auto; padding: 0 16px; }
    header.top {
      position: sticky; top: 0; z-index: 20; background: var(--bg);
      border-bottom: 1px solid var(--border);
    }
    .top-inner { display: flex; align-items: center; gap: 14px; padding: 10px 0; }
    .brand { font-weight: 600; font-size: 16px; white-space: nowrap; display: flex; align-items: center; gap: 7px; }
    .brand svg { color: #e05d38; }
    .searchbox {
      flex: 1; display: flex; align-items: center; gap: 8px; cursor: text;
      border: 1px solid var(--border); border-radius: 8px; padding: 6px 10px;
      color: var(--faint); background: var(--surface); font-size: 13px; min-width: 120px;
    }
    .searchbox kbd { margin-left: auto; }
    kbd {
      border: 1px solid var(--border); border-bottom-width: 2px; border-radius: 4px;
      padding: 0 5px; font-size: 11px; font-family: ui-monospace, Consolas, monospace; color: var(--muted);
    }
    nav.links { display: flex; gap: 14px; font-size: 13.5px; color: var(--muted); }
    nav.links a:hover { color: var(--fg); }
    #new-pill {
      display: none; align-items: center; gap: 8px; margin: 10px 0 0; padding: 6px 12px;
      background: var(--accent-bg); color: var(--accent); border-radius: 999px; font-size: 12.5px; width: fit-content;
    }
    #new-pill button { background: none; border: 0; color: inherit; font: inherit; cursor: pointer; text-decoration: underline; padding: 0; }
    main { padding: 6px 0 40px; }
    h2.day { font-size: 12.5px; font-weight: 600; color: var(--faint); text-transform: uppercase; letter-spacing: .04em; margin: 22px 0 4px; }
    .row { display: flex; gap: 12px; padding: 13px 10px; border-radius: 10px; position: relative; }
    .row + .row { border-top: 1px solid var(--border); }
    .row:hover, .row.sel { background: var(--surface); }
    .row.sel { outline: 1px solid var(--border); }
    .avatar {
      width: 36px; height: 36px; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center;
      font-size: 14px; font-weight: 600; background: hsl(var(--h) 60% 90%); color: hsl(var(--h) 60% 28%);
    }
    @media (prefers-color-scheme: dark) {
      .avatar { background: hsl(var(--h) 35% 26%); color: hsl(var(--h) 60% 80%); }
    }
    .row-main { flex: 1; min-width: 0; }
    .meta { margin: 0; font-size: 12.5px; color: var(--muted); display: flex; gap: 6px; flex-wrap: wrap; }
    .meta > * + *::before { content: '·'; margin-right: 6px; color: var(--faint); }
    .meta .src { font-weight: 600; }
    .meta .src:hover { color: var(--fg); }
    .title-line { display: flex; align-items: flex-start; gap: 10px; }
    .title-line .title { flex: 1; min-width: 0; }
    .src-pill {
      flex-shrink: 0; margin-top: 3px; font-size: 11px; font-weight: 600; white-space: nowrap;
      background: var(--accent-bg); color: var(--accent); border-radius: 999px; padding: 2px 10px;
      max-width: 180px; overflow: hidden; text-overflow: ellipsis;
    }
    .src-pill:hover { text-decoration: underline; }
    .title { margin: 2px 0 0; font-size: 15.5px; font-weight: 600; line-height: 1.4; }
    .title a:hover { text-decoration: underline; }
    .row.unread .title::before {
      content: ''; display: inline-block; width: 7px; height: 7px; border-radius: 50%;
      background: var(--accent); margin-right: 7px; vertical-align: 2px;
    }
    .summary {
      margin: 3px 0 6px; font-size: 13.5px; color: var(--muted);
      display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    }
    .tags { margin: 0; display: flex; gap: 6px; flex-wrap: wrap; }
    .chip {
      font-size: 11.5px; border: 1px solid var(--border); border-radius: 999px; padding: 1.5px 9px; color: var(--muted);
      background: var(--bg);
    }
    a.chip:hover { border-color: var(--faint); color: var(--fg); }
    .save-btn { background: none; border: 0; color: var(--faint); cursor: pointer; padding: 2px; height: fit-content; }
    .save-btn:hover { color: var(--fg); }
    .save-btn.saved { color: var(--accent); }
    .save-btn.saved .fill { fill: currentColor; }
    .pager { display: flex; align-items: center; gap: 16px; justify-content: center; margin: 26px 0; font-size: 13.5px; color: var(--muted); }
    .pager a { border: 1px solid var(--border); border-radius: 8px; padding: 6px 14px; }
    .pager a:hover { background: var(--surface); }
    footer.hints {
      border-top: 1px solid var(--border); color: var(--faint); font-size: 12px;
      padding: 12px 0 30px;
    }
    footer.hints .wrap { display: flex; gap: 16px; flex-wrap: wrap; }
    footer.hints .right { margin-left: auto; }
    table.sources { width: 100%; border-collapse: collapse; font-size: 13.5px; margin-top: 14px; }
    table.sources th { text-align: left; font-size: 12px; color: var(--faint); font-weight: 600; padding: 6px 8px; border-bottom: 1px solid var(--border); }
    table.sources td { padding: 7px 8px; border-bottom: 1px solid var(--border); vertical-align: top; }
    .badge { font-size: 11.5px; border-radius: 999px; padding: 1.5px 9px; font-weight: 600; }
    .badge.active { background: color-mix(in srgb, var(--ok) 14%, transparent); color: var(--ok); }
    .badge.backfilling { background: var(--accent-bg); color: var(--accent); }
    .badge.failing, .badge.quarantined { background: color-mix(in srgb, var(--danger) 12%, transparent); color: var(--danger); }
    .badge.new { background: var(--surface); color: var(--muted); }
    #search-overlay {
      position: fixed; inset: 0; z-index: 50; background: color-mix(in srgb, var(--fg) 28%, transparent);
      display: flex; justify-content: center; align-items: flex-start; padding: 8vh 16px 0;
    }
    #search-overlay[hidden] { display: none; }
    .search-panel {
      width: 100%; max-width: 640px; background: var(--bg); border: 1px solid var(--border);
      border-radius: 14px; overflow: hidden; box-shadow: 0 18px 50px rgb(0 0 0 / .25);
    }
    .search-head { display: flex; align-items: center; gap: 10px; padding: 12px 14px; border-bottom: 1px solid var(--border); }
    .search-head input { flex: 1; border: 0; outline: 0; background: none; color: var(--fg); font: inherit; font-size: 15px; }
    .search-filters { display: flex; gap: 8px; padding: 9px 14px; border-bottom: 1px solid var(--border); }
    .search-filters select {
      background: var(--surface); color: var(--muted); border: 1px solid var(--border); border-radius: 8px;
      font-size: 12.5px; padding: 4px 8px; max-width: 46%;
    }
    .search-results { max-height: 56vh; overflow-y: auto; padding: 4px 8px 8px; }
    .sr { display: block; padding: 9px 8px; border-radius: 8px; }
    .sr:hover, .sr.sel { background: var(--surface); }
    .sr .meta { font-size: 12px; }
    .sr .t { font-weight: 600; font-size: 14px; margin: 1px 0; }
    .sr .x { font-size: 12.5px; color: var(--muted); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .sr mark { background: var(--accent-bg); color: var(--accent); border-radius: 3px; padding: 0 1px; }
    .search-empty { color: var(--faint); font-size: 13px; padding: 18px 12px; text-align: center; }
    .page-head h1 { font-size: 19px; margin: 18px 0 2px; }
    .page-head p { margin: 0; color: var(--muted); font-size: 13.5px; }
  </style>
</head>
<body data-base={root}>
  <header class="top">
    <div class="wrap top-inner">
      <a class="brand" href={root}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4 4a16 16 0 0 1 16 16h-3A13 13 0 0 0 4 7Zm0 7a9 9 0 0 1 9 9h-3a6 6 0 0 0-6-6Zm0 7a2 2 0 1 1 0 4 2 2 0 0 1 0-4Z"/></svg>
        Engineering reads
      </a>
      <button class="searchbox" id="search-open" aria-label="Search posts">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
        <span>Search {postCount} posts…</span>
        <kbd>/</kbd>
      </button>
      <nav class="links">
        <a href={root}>Latest</a>
        <a href={`${root}sources/`}>Sources</a>
        <a href={`${root}saved/`}>Saved</a>
      </nav>
    </div>
  </header>
  <div class="wrap">
    <div id="new-pill"><span id="new-count"></span><button id="mark-read">Mark all read</button></div>
  </div>
  <main class="wrap">
    <slot />
  </main>
  <footer class="hints">
    <div class="wrap">
      <span><kbd>j</kbd> <kbd>k</kbd> navigate</span>
      <span><kbd>o</kbd> open</span>
      <span><kbd>s</kbd> save</span>
      <span><kbd>/</kbd> search</span>
      <span class="right"><slot name="footer-right" /></span>
    </div>
  </footer>
  <div id="search-overlay" hidden>
    <div class="search-panel" role="dialog" aria-label="Search">
      <div class="search-head">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
        <input id="search-input" placeholder={`Search ${postCount} posts by title, summary or tag…`} autocomplete="off" />
        <kbd>esc</kbd>
      </div>
      <div class="search-filters">
        <select id="f-source" aria-label="Filter by source"><option value="">All sources</option></select>
        <select id="f-tag" aria-label="Filter by tag"><option value="">All tags</option></select>
      </div>
      <div id="search-results" class="search-results"><p class="search-empty">Type to search.</p></div>
    </div>
  </div>
  <script src={`${root}app.js`} defer></script>
</body>
</html>
