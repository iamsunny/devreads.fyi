---
import Base from '../layouts/Base.astro';
const root = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---
<Base title="404 — devreads.fyi">
  <div class="page-head">
    <h1 style="font-family: var(--mono);">404: command not found</h1>
    <p>FYI: that page doesn't exist. <a href={root} style="text-decoration: underline; font-family: var(--mono);">cd ~/</a></p>
  </div>
</Base>
