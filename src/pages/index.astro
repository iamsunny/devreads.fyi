---
import Base from '../layouts/Base.astro';
import Listing from '../components/Listing.astro';
import Pagination from '../components/Pagination.astro';
import AdSlot from '../components/AdSlot.astro';
import { pageSlice, pageCount, posts, sites } from '../lib/data.mjs';
---
<Base>
  <AdSlot />
  <Listing posts={pageSlice(1)} />
  <Pagination page={1} total={pageCount()} />
  <span slot="footer-right">FYI: {posts.length.toLocaleString()} posts from {sites.length} sources</span>
</Base>
